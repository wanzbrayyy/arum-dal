<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="<%= theme.background %>">
    <title><%= outletName %> - Menu Digital</title>
    <link rel="manifest" href="/manifest.webmanifest">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/client-app.css">
</head>
<body>
    <div class="app-shell">
        <header class="topbar">
            <div class="topbar-inner">
                <div class="topbar-meta">
                    <div>
                        <div class="brand-title">ARUM DALU</div>
                        <div class="brand-subtitle">Digital Menu &amp; Table Ordering</div>
                    </div>
                    <div class="table-pill" id="tableBadge"><%= tableName %></div>
                </div>
                <div class="toolbar">
                    <button class="icon-btn" id="themeToggle" type="button"><i class="fa-solid fa-circle-half-stroke"></i></button>
                    <button class="icon-btn" id="languageToggle" type="button"><i class="fa-solid fa-language"></i></button>
                    <button class="icon-btn" id="serviceMenuBtn" type="button"><i class="fa-solid fa-bars"></i></button>
                    <button class="soft-pill" id="installBtn" type="button">PWA</button>
                </div>
            </div>
        </header>

        <main>
            <section class="page-section">
                <div class="hero-card">
                    <div class="soft-pill">Scan QR - Order dari meja</div>
                    <h1 id="heroTitle"><%= outletName %></h1>
                    <p id="heroSubtitle">Menu digital untuk pelanggan Arum Dalu.</p>
                    <div class="hero-grid">
                        <div class="mini-stat">
                            <div class="mini-stat-label">Outlet</div>
                            <div class="mini-stat-value" id="miniOutlet"><%= outletName %></div>
                        </div>
                        <div class="mini-stat">
                            <div class="mini-stat-label">Meja</div>
                            <div class="mini-stat-value" id="miniTable"><%= tableName %></div>
                        </div>
                        <div class="mini-stat">
                            <div class="mini-stat-label">Pajak</div>
                            <div class="mini-stat-value" id="miniTax">10%</div>
                        </div>
                        <div class="mini-stat">
                            <div class="mini-stat-label">Service</div>
                            <div class="mini-stat-value" id="miniService">5%</div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="page-section">
                <div class="section-heading">
                    <h2>Identitas Pemesan</h2>
                    <span class="muted">Nama dan WhatsApp wajib agar order lengkap</span>
                </div>
                <div class="info-grid">
                    <input class="field" id="customerName" placeholder="Nama pelanggan">
                    <input class="field" id="customerPhone" placeholder="Nomor WhatsApp">
                    <input class="field" id="customerEmail" placeholder="Email pelanggan" type="email">
                    <select class="select-box" id="diningOption">
                        <option value="dine-in">Dine In</option>
                        <option value="takeaway">Take Away</option>
                    </select>
                    <select class="select-box" id="paymentPreference">
                        <option value="pay_at_cashier">Bayar di kasir</option>
                        <option value="pay_at_table">Bayar dari meja</option>
                        <option value="qris">QRIS</option>
                    </select>
                    <input class="field" id="voucherCode" placeholder="Kode voucher">
                    <input class="field" id="takeawayAddress" placeholder="Alamat takeaway / catatan antar">
                </div>
                <div class="card hidden" id="memberCard">
                    <div class="section-heading">
                        <h2>Info Member</h2>
                        <span class="soft-pill" id="memberTierBadge">Bronze</span>
                    </div>
                    <div class="status-row">
                        <span class="muted">Nama</span>
                        <strong id="memberNameValue">-</strong>
                    </div>
                    <div class="status-row" style="margin-top:8px;">
                        <span class="muted">Poin</span>
                        <strong id="memberPointsValue">0</strong>
                    </div>
                    <div class="status-row" style="margin-top:8px;">
                        <span class="muted">Kode</span>
                        <strong id="memberCodeValue">-</strong>
                    </div>
                </div>
                <div class="promo-strip" id="promoRow"></div>
                <div class="info-grid" style="margin-top:12px;">
                    <div class="card quick-card">
                        <div class="muted">Metode Bayar</div>
                        <strong id="paymentPreferenceLabel">Bayar di kasir</strong>
                    </div>
                    <div class="card quick-card">
                        <div class="muted">Mode Pesanan</div>
                        <strong id="diningOptionLabel">Dine In</strong>
                    </div>
                </div>
                <textarea class="field" id="orderNote" placeholder="Catatan order, request khusus, atau patokan level rasa" style="margin-top:10px; min-height:92px; resize:vertical;"></textarea>
            </section>

            <section class="page-section">
                <div class="section-heading">
                    <h2>Aksi Cepat Pelayanan</h2>
                    <span class="muted">Sekarang lewat menu hamburger agar lebih ringkas</span>
                </div>
                <div class="card quick-card">
                    <div class="muted">Alert meja, panggil pelayan, dan minta tagihan kini ada di tombol menu kanan atas.</div>
                    <button class="action-chip" id="openServicePanelBtn" type="button" style="margin-top:12px;">Buka Menu Pelayanan</button>
                </div>
            </section>

            <section class="page-section">
                <div class="section-heading">
                    <h2>Rekomendasi &amp; Promo</h2>
                    <span class="muted">Upsell otomatis dari katalog</span>
                </div>
                <div class="recommendation-row" id="recommendationRow"></div>
            </section>

            <section class="page-section">
                <div class="section-heading">
                    <h2>Menu</h2>
                    <span class="muted">Pilih, custom, lalu kirim ke kasir</span>
                </div>
                <input class="search-box" id="searchInput" placeholder="Cari menu, barcode, atau kategori">
                <div class="category-row" id="categoryRow" style="margin-top:12px;"></div>
                <div class="product-list" id="productList" style="margin-top:14px;"></div>
                <div class="empty-state hidden" id="emptyProducts">Menu tidak ditemukan untuk filter saat ini.</div>
            </section>

            <section class="page-section">
                <div class="status-card hidden" id="statusCard">
                    <div class="section-heading">
                        <h2>Status Pesanan Terakhir</h2>
                        <span class="status-badge" id="statusBadge">PENDING</span>
                    </div>
                    <div class="muted" id="statusText">Pesanan menunggu diproses.</div>
                    <div class="soft-pill" style="margin-top:12px;" id="latestOrderMeta">Belum ada order aktif</div>
                    <div class="status-row" style="margin-top:12px;">
                        <span class="muted">Nomor order</span>
                        <strong id="statusOrderCode">-</strong>
                    </div>
                    <div class="status-row" style="margin-top:8px;">
                        <span class="muted">Queue / Pembayaran</span>
                        <strong id="statusQueueInfo">-</strong>
                    </div>
                    <div class="action-grid" style="margin-top:14px;">
                        <button class="action-chip" id="refreshStatusBtn" type="button">Refresh status</button>
                        <button class="action-chip" id="shareOrderBtn" type="button">Bagikan order</button>
                    </div>
                    <button class="secondary-btn" id="feedbackBtn" type="button" style="margin-top:14px;">Kirim feedback cepat</button>
                </div>
            </section>
        </main>
    </div>

    <div class="cart-backdrop hidden" id="cartBackdrop"></div>
    <div class="floating-cart collapsed" id="floatingCart">
        <button class="cart-toggle-btn" id="cartToggleBtn" type="button" aria-expanded="false">
            <span>Keranjang Pelanggan</span>
            <strong id="cartToggleSummary">0 item - Rp 0</strong>
        </button>
        <div class="cart-sheet" id="cartSheet">
            <div class="cart-header">
                <div>
                    <div style="font-weight:700;">Keranjang</div>
                    <div class="muted" id="cartMeta">Belum ada item di keranjang.</div>
                </div>
                <div style="display:flex; gap:8px; align-items:center;">
                    <div class="soft-pill" id="cartCount">0 item</div>
                    <button class="icon-btn" id="cartCloseBtn" type="button" aria-label="Tutup keranjang"><i class="fa-solid fa-xmark"></i></button>
                </div>
            </div>
            <div class="empty-state" id="cartEmpty">Belum ada item di keranjang.</div>
            <div id="cartLines"></div>
            <div class="cart-summary">
                <div class="cart-summary-row"><span class="muted">Subtotal</span><strong id="subtotalValue">Rp 0</strong></div>
                <div class="cart-summary-row" style="margin-top:8px;"><span class="muted">Diskon</span><strong id="discountValue">Rp 0</strong></div>
                <div class="cart-summary-row" style="margin-top:8px;"><span class="muted">Service</span><strong id="serviceValue">Rp 0</strong></div>
                <div class="cart-summary-row" style="margin-top:8px;"><span class="muted">Pajak</span><strong id="taxValue">Rp 0</strong></div>
                <div class="cart-summary-row" style="margin-top:8px;"><span class="muted">Pembulatan</span><strong id="roundingValue">Rp 0</strong></div>
                <div class="cart-summary-row" style="margin-top:10px; font-size:18px;"><span>Total</span><strong id="totalValue">Rp 0</strong></div>
            </div>
            <button class="primary-btn" id="checkoutBtn" type="button">Kirim Pesanan</button>
        </div>
    </div>

    <div class="service-backdrop hidden" id="serviceBackdrop"></div>
    <div class="service-drawer hidden" id="serviceDrawer">
        <div class="section-heading">
            <h2>Menu Alert Meja</h2>
            <button class="icon-btn" id="serviceCloseBtn" type="button"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="muted">Pilih aksi yang ingin dikirim ke kasir dari meja pelanggan.</div>
        <div class="action-grid" id="serviceActionRow" style="margin-top:14px;"></div>
    </div>

    <div class="loading-overlay hidden" id="clientLoadingOverlay">
        <div class="loading-card">
            <div class="loading-spinner"></div>
            <strong id="clientLoadingText">Sedang memuat...</strong>
        </div>
    </div>

    <script>
        window.CLIENT_CONTEXT = {
            uniqueIdentifier: '<%= uniqueIdentifier %>'
        };
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js').catch(() => {});
            });
        }
    </script>
    <script src="/js/client-app.js"></script>
</body>
</html>
